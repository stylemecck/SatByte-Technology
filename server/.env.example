PORT=5000
MONGODB_URI=
JWT_SECRET=change-this-to-a-long-random-string

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma-separated origins for CORS
CLIENT_URL=http://localhost:5173

# Bootstrap admin (scripts/seedAdmin.js)
SEED_ADMIN_EMAIL=admin@satbyte.in
SEED_ADMIN_PASSWORD=

# Optional: allow POST /api/auth/register for one-off signup
ALLOW_REGISTER=false

# Optional Nodemailer (POST /api/contact)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=info@satbyte.in

# Stripe Checkout (pricing page — Pay with Stripe)
STRIPE_SECRET_KEY=
# Optional: Stripe Dashboard Price IDs (INR). If unset, server uses one-time price_data for ₹4,999 / ₹9,999 / ₹19,999.
# STRIPE_PRICE_BASIC=price_xxx
# STRIPE_PRICE_STANDARD=price_xxx
# STRIPE_PRICE_PREMIUM=price_xxx



